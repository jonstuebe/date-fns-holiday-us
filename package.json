{
  "name": "date-fns-holidays",
  "description": "The purpose of this project is to give an interface to work with holidays using date-fns",
  "version": "1.1.1-beta.0",
  "author": "Khiet Tam Nguyen",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "date-fns",
    "date",
    "holiday",
    "holidays"
  ],
  "repository": {
    "url": "https://github.com/nktnet1/date-fns-holidays"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "docs:gen": "typedoc && shx cp docs/README.md README.md",
    "lint": "biome lint",
    "format": "biome format",
    "check": "biome check",
    "prepublishOnly": "pnpm build && pnpm docs:gen"
  },
  "peerDependencies": {
    "date-fns": ">= 2.x.x"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@vitest/coverage-v8": "^4.1.8",
    "date-fns": "^4.4.0",
    "shx": "^0.4.0",
    "tsdown": "^0.22.2",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "packageManager": "pnpm@11.6.0"
}
